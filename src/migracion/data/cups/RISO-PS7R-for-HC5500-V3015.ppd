userdict /PDFVars known {
 PDFVars /docSetupDone get {
  PDFVars /_defaultcolortransfer get aload pop setcolortransfer
  PDFVars /InitAll [ PDFVars /InitAll get /exec cvx { PDFVars /_defaultcolortransfer get aload pop setcolortransfer } /exec cvx ] cvx put
 } if
} if
"
*End
*TL_ColorSimulation Simulate/ACTIVADO: "
%PPD_ColorSimulation=1
% for Acrobat
userdict /PDFVars known {
 PDFVars /docSetupDone get {
  PDFVars /_defaultcolortransfer get aload pop setcolortransfer
  PDFVars /InitAll [ PDFVars /InitAll get /exec cvx { PDFVars /_defaultcolortransfer get aload pop setcolortransfer } /exec cvx ] cvx put
 } if
} if
"
*End
*CloseUI: *TL_ColorSimulation

