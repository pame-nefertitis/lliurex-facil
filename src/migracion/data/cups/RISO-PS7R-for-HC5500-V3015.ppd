*NTLDropMax 6/6: "%PPD_DropMax=6"
*NTLDropMax 7/7: "%PPD_DropMax=7"
*?NTLDropMax: "
  (DropMaxMode ?\0) 16 string /CPSI /ProcSet findresource
  /externalcommand get exec pop
  dup (0) eq { pop (Auto) } {
   dup (1) eq { pop (1) } {
    dup (2) eq { pop (2) } {
     dup (3) eq { pop (3) } {
      dup (4) eq { pop (4) } {
       dup (5) eq { pop (5) } {
        dup (6) eq { pop (6) } {
         dup (7) eq { pop (7) } {
            pop (Auto)
         } ifelse
        } ifelse
       } ifelse
      } ifelse
     } ifelse
    } ifelse
   } ifelse
  } ifelse
  ="
