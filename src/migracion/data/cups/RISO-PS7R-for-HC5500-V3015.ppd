*NTLLayout None/DESACTIVADO: "
%PPD_Layout=0
%PPD_LayoutNum=1
"
*End
*NTLLayout Copy/Multi-arriba: "
%PPD_Layout=1
"
*End
*NTLLayout Page/Multi-arriba: "
%PPD_Layout=2
"
*End
*NTLLayout Book/Folleto: "
%PPD_Layout=3
%PPD_LayoutNum=2
"
*End
*NTLLayout Fold/Pliego: "
%PPD_Layout=4
%PPD_LayoutNum=4
"
*End
*?NTLLayout: "
  (Layout ?\0) 16 string /CPSI /ProcSet findresource
  /externalcommand get exec pop
  dup (0) eq { pop (None) } {
   dup (1) eq { pop (Copy) } {
    dup (2) eq { pop (Page) } {
     dup (3) eq { pop (Copy) } {
      dup (4) eq { pop (Fold) } {
        pop (None)
      } ifelse
     } ifelse
    } ifelse
   } ifelse
  } ifelse
  ="
*End
*CloseUI: *NTLLayout

