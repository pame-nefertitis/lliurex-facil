*?FontList: "
  save
    (*) {cvn ==} 128 string /Font resourceforall
    (*) = flush
  restore"
*End
*?FontQuery: "
  save
    { count 1 gt
      { exch dup 127 string cvs (/) print print (:) print
      /Font resourcestatus {pop pop (Yes)} {(No)} ifelse =
      } { exit } ifelse
    } bind loop
    (*) = flush
  restore"
*End

*% --------------- Printer Messages ---------------

*% ----- Consumables
*PrinterError: "paper empty"
*% ----- Engine
*PrinterError: "paper jam"
*PrinterError: "option error"
*PrinterError: "check printer control panel"
*PrinterError: "fatal, check printer control panel"
*PrinterError: "check printer power and cable connection"
*PrinterError: "communication error, call service!"
*PrinterError: "interface board error, call service!"
*PrinterError: "SERIAL NUMBER MISMATCH, call service!"

*% ----- General
*Status: "idle"
*Status: "busy"
*Status: "waiting"
*Status: "printing"
*Status: "initializing"
*Status: "offline, wait for a user action"
*% ----- Consumables
*Status: "PrinterError: paper empty"
*Status: "PrinterError: staples empty"
*% ----- Engine
*Status: "PrinterError: paper jam"
*Status: "PrinterError: option error"
*Status: "PrinterError: check printer control panel"
*Status: "PrinterError: fatal, check printer control panel"
*Status: "PrinterError: check printer power and cable connection"
*Status: "PrinterError: communication error, call service!"
*Status: "PrinterError: interface board error, call service!"
*Status: "PrinterError: SERIAL NUMBER MISMATCH, call service!"

*Source: "EtherTalk"
*Source: "Parallel"
*Source: "LPR"

*Message: "%%[ exitserver: permanent state may be changed ]%%"
*Message: "%%[ Flushing: rest of job (to end-of-file) will be ignored ]%%"
*Message: "\FontName\ not found, using Courier"

*% --------------- Color Separation ---------------

*DefaultColorSep: ProcessBlack.71lpi.300x300dpi/71 lpi / 300 dpi

*% ----- 71 lpi / 300 dpi
*ColorSepScreenAngle ProcessBlack.71lpi.300x300dpi/71 lpi / 300 dpi: "45"
*ColorSepScreenAngle ProcessCyan.71lpi.300x300dpi/71 lpi / 300 dpi: "105"
*ColorSepScreenAngle ProcessMagenta.71lpi.300x300dpi/71 lpi / 300 dpi: "75"
*ColorSepScreenAngle ProcessYellow.71lpi.300x300dpi/71 lpi / 300 dpi: "90"
*ColorSepScreenFreq ProcessBlack.71lpi.300x300dpi/71 lpi / 300 dpi: "71"
*ColorSepScreenFreq ProcessCyan.71lpi.300x300dpi/71 lpi / 300 dpi: "71"
*ColorSepScreenFreq ProcessMagenta.71lpi.300x300dpi/71 lpi / 300 dpi: "71"
*ColorSepScreenFreq ProcessYellow.71lpi.300x300dpi/71 lpi / 300 dpi: "71"

